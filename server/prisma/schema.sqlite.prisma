// HypoManažer – datový model (SQLite pro lokální vývoj)
// Používá se když DATABASE_URL je file:./dev.db (nebo nezačíná na postgresql://)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// --- Enums ---
enum LoanType {
  PURCHASE
  REFINANCE
  NON_PURPOSE
}

enum LeadSource {
  OWN
  REFERRER
  MARKETPLACE
}

enum LeadStatus {
  DRAFT
  SENT
  OPENED
  IN_PROGRESS
  SUBMITTED
  CONVERTED
  EXPIRED
  DISQUALIFIED
}

enum IntakeSessionState {
  CREATED
  SENT
  OPENED
  IN_PROGRESS
  SUBMITTED
  CONVERTED
  EXPIRED
}

enum PersonRole {
  APPLICANT
  CO_APPLICANT
}

enum DocType {
  ID_FRONT
  ID_BACK
  TAX_RETURN
  BANK_STATEMENT
  INCOME_CONFIRMATION
  OTHER
}

enum UploadSlotStatus {
  EMPTY
  UPLOADED
  PROCESSED
  ERROR
}

enum LeadEventType {
  LINK_CREATED
  LINK_SENT_SMS
  LINK_SENT_EMAIL
  LINK_OPENED
  INTAKE_PROGRESS
  UPLOAD_ADDED
  SUBMITTED
  CONVERTED
  EXPIRED
  ERROR
}

enum ReferrerType {
  ALLIANZ
  REAL_ESTATE
  DEVELOPER
  INTERNAL
  OTHER
}

enum PayoutMethod {
  NONE
  BANK_TRANSFER
  INVOICE
}

enum ReferrerEventType {
  CREATED
  INVITED
  LEAD_CREATED
  STATUS_CHANGED
  ERROR
}

enum UploadedBy {
  CLIENT
  ADVISOR
  REFERRER
}

enum IncomeType {
  EMPLOYED
  SELF_EMPLOYED
  BOTH
}

enum DealStatus {
  NEW
  DATA_EXTRACTED
  SENT_TO_BANK
  APPROVED
  SIGNED_BY_CLIENT
  CLOSED
  LOST
}

enum BankCalculatorCode {
  RB
  UCB
}

enum BankTemplateMappingStatus {
  UNKNOWN
  VALID
  INVALID
  NEEDS_REVIEW
}

enum BankCalculationStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  MISSING_TEMPLATE
  MOCK
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String     // bcrypt hash
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cases     Case[]
  leads     Lead[]
  referrers Referrer[]
  browserExtensionPairings BrowserExtensionPairing[]
  browserExtensionDevices   BrowserExtensionDevice[]
  browserExtensionMappings  BrowserExtensionMapping[]
  bankTemplates             BankTemplate[]
  bankCalculationRuns       BankCalculationRun[]
  calendarEvents            CalendarEvent[] @relation("CalendarEvents")
  googleOAuthToken          GoogleOAuthToken?
}

model Lead {
  id                String       @id @default(cuid())
  ownerUserId       String
  owner             User         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  firstName         String
  lastName          String
  email             String?
  phone             String?
  loanType          LoanType
  note              String?
  source            LeadSource   @default(OWN)
  referrerId        String?
  referrer          Referrer?    @relation(fields: [referrerId], references: [id], onDelete: SetNull)
  status            LeadStatus   @default(DRAFT)
  convertedCase     Case?       @relation("LeadCase") // Case.leadId = this Lead
  intakeSessionId   String?
  intakeSession     IntakeSession?
  visibility        String?      // PRIVATE | TEAM | MARKETPLACE
  priceCzk         Int?
  territory         String?
  qualityScore      Int?
  deletedAt         DateTime?    // soft delete – lead v koši
  agreedCommissionPercent Float? // kopie z tipaře při vytvoření, u leadu lze měnit samostatně
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  leadEvents        LeadEvent[]
  calendarEvents    CalendarEvent[]
  @@unique([intakeSessionId])
}

model IntakeSession {
  id            String             @id @default(cuid())
  leadId        String             @unique
  lead          Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tokenHash     String             @unique
  intakeLink    String?            // plný odkaz pro kopírování (ukládáme při vytvoření/regeneraci)
  expiresAt     DateTime
  openedAt      DateTime?
  submittedAt   DateTime?
  consentAt     DateTime?
  consentVersion String?
  state         IntakeSessionState @default(CREATED)
  ico               String?            // IČO hlavního žadatele (OSVČ / firma)
  coApplicantIco    String?            // IČO spolužadatele (OSVČ / firma)
  intakeMetadata    String?            // JSON: domácnost, vztah spolužadatele, poznámka (klient intake wizard)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  uploadSlots     UploadSlot[]
}

model UploadSlot {
  id               String           @id @default(cuid())
  intakeSessionId  String
  intakeSession    IntakeSession    @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)
  personRole       PersonRole
  docType          DocType
  period           String?
  required         Boolean          @default(true)
  status           UploadSlotStatus  @default(EMPTY)
  storageKey       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Case {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId          String?          @unique
  lead            Lead?            @relation("LeadCase", fields: [leadId], references: [id], onDelete: SetNull)
  loanType        String?          // převod z Lead.loanType po konverzi
  jmeno           String           // hlavní klient (první osoba nebo ručně)
  datum           String           // datum založení např. "13.2.2025"
  status          String           @default("novy") // novy | data-vytazena | doplneno
  dealStatus      DealStatus?      // pipeline: NEW, SENT_TO_BANK, APPROVED, ...
  vyseUveru       Int?
  ucel            String?
  isActive        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  extractedData   ExtractedData[]
  files           CaseFile[]
  persons         Person[]
  documents       Document[]
  bankCalculationRuns BankCalculationRun[]
  calendarEvents  CalendarEvent[]
}

model Person {
  id              String    @id @default(cuid())
  caseId          String
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  role            PersonRole
  firstName       String?
  lastName        String?
  birthNumber     String?
  dob             String?
  address         String?
  docNumber       String?
  docValidTo      String?
  incomeType      IncomeType?
  selfEmployedIco String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Document {
  id          String     @id @default(cuid())
  caseId      String
  case        Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personRole  PersonRole
  docType     DocType
  period      String?
  storageKey  String
  originalName String
  mimeType    String?
  sizeBytes   Int?
  uploadedBy  UploadedBy
  createdAt   DateTime   @default(now())
}

model LeadEvent {
  id        String        @id @default(cuid())
  leadId    String
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      LeadEventType
  payload   String?       // JSON
  createdAt DateTime      @default(now())
}

model Referrer {
  id                  String           @id @default(cuid())
  ownerUserId         String
  owner               User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  type                ReferrerType
  displayName         String
  registrationNumber  String?
  email               String?
  phone               String?
  payoutMethod        PayoutMethod     @default(NONE)
  agreedCommissionPercent Float?     // výchozí pro nové leady od tipaře
  bankAccount         String?
  invoiceCompanyName  String?
  invoiceIco          String?
  invoiceDic          String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  blockedAt           DateTime?        // přesun do blokace před trvalým smazáním
  leads               Lead[]
  referralLinks       ReferralLink[]
  referrerEvents      ReferrerEvent[]
}

model ReferralLink {
  id          String    @id @default(cuid())
  referrerId  String
  referrer    Referrer  @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ReferrerEvent {
  id         String            @id @default(cuid())
  referrerId String
  referrer   Referrer          @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  type       ReferrerEventType
  payload    String?            // JSON
  createdAt  DateTime          @default(now())
}

model ExtractedData {
  id              String   @id @default(cuid())
  caseId          String
  case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personIndex     Int      @default(0)    // 0 = klient, 1 = partner, …
  jmeno           String   @default("")
  prijmeni        String   @default("")
  rc              String   @default("")
  adresa          String   @default("")
  prijmy          Int      @default(0)    // v Kč
  vydaje          Int      @default(0)    // v Kč
  dpData          String?  // JSON: { "31": 12345, "37": 0, ... } – řádky DAP
  vypisyPrijmy    String?  // JSON: příjmy z výpisů BU po měsících
  cisloDokladu    String?  // číslo OP – vytaženo z OP
  datumVydani     String?  // datum vydání OP
  platnostDo      String?  // platnost OP do
  vydavajiciUrad  String?  // vydávající úřad
  opRawText       String?  // raw OCR/Doctly výstup – pro re-parse bez volání API
  opDoctlyJson    String?  // raw JSON z Doctly ID extractoru
  datumNarozeni   String?  // datum narození – z OP nebo z rodného čísla
  mistoNarozeni   String?  // místo narození
  pohlavi         String?  // M/Ž nebo Muž/Žena – z OP nebo z rodného čísla
  narodnost       String?  // státní občanství
  rodinnyStav     String?  // svobodný, ženatý, vdaná, rozvedený, vdovec, vdova
  @@unique([caseId, personIndex])
}

model CaseFile {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type      String   // op-predni | op-zadni | danove | vypisy
  name      String   // původní název souboru
  path      String   // relativní cesta na disku (uploads/caseId/filename)
  mimeType  String?  @default("application/octet-stream")
  createdAt DateTime @default(now())
}

/// Nahraná .xlsm šablona banky – vždy per uživatel (žádný globální default).
model BankTemplate {
  id               String                    @id @default(cuid())
  userId           String
  user             User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankCode         BankCalculatorCode
  originalFileName String
  mimeType         String
  storageKey       String                    @unique // relativní pod UPLOAD_DIR
  mappingStatus    BankTemplateMappingStatus @default(UNKNOWN)
  mappingVersion   Int?
  contentHash      String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  runs             BankCalculationRun[]

  @@unique([userId, bankCode])
}

model BankCalculationRun {
  id                      String               @id @default(cuid())
  userId                  String
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId                  String
  case                    Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  bankCode                BankCalculatorCode
  templateId              String?
  template                BankTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  status                  BankCalculationStatus
  errorMessage            String?
  generatedFileStorageKey String?
  maxLoanAmount           Int?
  monthlyPayment          Int?
  dsti                    Float?
  dti                     Float?
  pdsti                   Float?
  minRequiredIncome       Int?
  passFail                String?
  outcomeLabel            String?
  metaJson                String?
  startedAt               DateTime             @default(now())
  finishedAt              DateTime?

  @@index([caseId, bankCode])
  @@index([userId, caseId])
}

// --- Google OAuth tokeny ---
model GoogleOAuthToken {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email         String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scopes        String   // JSON array
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- Kalendář / úkoly ---
model CalendarEvent {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation("CalendarEvents", fields: [userId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  type             String    // meeting | task | reminder | call
  startAt          DateTime
  endAt            DateTime?
  allDay           Boolean   @default(false)
  location         String?
  caseId           String?
  case             Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  leadId           String?
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  googleEventId    String?   @unique
  googleCalendarId String?
  lastSyncedAt     DateTime?
  reminderMinutes  Int?
  status           String    @default("active") // active | completed | cancelled
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// --- Integrace: rozšíření pro prohlížeč (pairing + refresh token) ---
model BrowserExtensionPairing {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userCode  String    @unique  // kód zobrazený uživateli (např. ABCD-EFGH)
  expiresAt DateTime
  usedAt    DateTime? // po použití při pairing/confirm
  createdAt DateTime  @default(now())
}

model BrowserExtensionDevice {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  installationId   String   @unique  // UUID z rozšíření
  refreshTokenHash String   // hash refresh tokenu
  expiresAt        DateTime
  createdAt        DateTime @default(now())
}

// Mapping packy pro bankovní formuláře, ukládané z rozšíření přes API.
model BrowserExtensionMapping {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankId     String
  hostname   String   // např. "noby.cz" bez www
  pathPrefix String   // např. "/modelation/mortgage"
  packJson   String   // celé JSON tělo mapping packu
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, hostname, pathPrefix])
}
