{
  "name": "hypomanager-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "cd .. && npm run dev:all",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "npm run test && node scripts/select-schema.js && prisma generate && tsc",
    "test": "node --import tsx --test src/lib/tokens.test.ts src/lib/referrerStatus.test.ts src/lib/intakeValidation.test.ts src/modules/bankCalculators/excelMapping.test.ts",
    "start": "sh scripts/start.sh",
    "worker": "node dist/worker.js",
    "db:generate": "node scripts/select-schema.js && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "node scripts/select-schema.js && prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.6.2",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.13.0",
    "prisma": "^7.0.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.1.0",
    "twilio": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
