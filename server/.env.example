# Zkopírujte na .env a vyplňte

# Povinné
# Lokál: SQLite – stačí file:./dev.db (vytvoří se v server/prisma/)
# Produkce (Railway): nastavte postgresql://user:password@host:5432/dbname v Railway Variables
DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="nahradte-nahodnym-tajemstvem-min-32-znaku"

# Server
PORT=4000
JWT_EXPIRES_IN="7d"
UPLOAD_DIR=./uploads

# URL frontendu – pro generování odkazů (intake, tipař). POVINNÉ v produkci.
# Lokál: výchozí http://localhost:3000 (nebo např. FRONTEND_URL=http://localhost:5173)
# Produkce (Railway): nastavte na URL vašeho frontendu, např.:
#   FRONTEND_URL=https://react-frontend-production-85c7.up.railway.app
# Bez nastavení v produkci budou odkazy obsahovat localhost a nebudou fungovat.
# FRONTEND_URL=http://localhost:3000

# Redis – pro asynchronní úkoly (worker: odeslání linků, konverze leadů, notifikace tipařů)
# Bez REDIS_URL API běží se synchronním fallbackem
# REDIS_URL=redis://localhost:6379

# SMS (Twilio) – odesílání intake a tipařských odkazů, notifikace
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+420123456789

# E-mail (Resend) – odesílání intake a tipařských odkazů, notifikace
# RESEND_API_KEY=re_...
# RESEND_FROM=hypo@vasedomena.cz

# Doctly – AI extrakce dokumentů (volitelné)
# DOCTLY_API_KEY=dk_live_...

# LLM pro vytažení dat z OP (volitelné; bez klíče se použije regex)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1
